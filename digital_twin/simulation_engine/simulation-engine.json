  ],
  "actionLibrary": [
    { "id": "reduce_scope", "description": "Reduce operational scope to lower-risk subset.", "category": "ScopeControl" },
    { "id": "apply_soft_realignment", "description": "Apply non-coercive goal realignment at local level.", "category": "ConstraintControl" },
    { "id": "switch_to_constraint_first", "description": "Prioritize constraints over performance objectives.", "category": "ConstraintControl" },
    { "id": "slow_operational_tempo", "description": "Reduce tempo to sustainable levels.", "category": "ScopeControl" },
    { "id": "request_supervisor_review", "description": "Request supervisory review of current tempo and load.", "category": "GovernanceControl" },
    { "id": "prioritize_tasks", "description": "Reorder tasks by criticality under resource strain.", "category": "ScopeControl" },
    { "id": "shed_noncritical_load", "description": "Drop or defer noncritical tasks.", "category": "ScopeControl" },
    { "id": "pause_nonessential_tasks", "description": "Pause tasks that are not essential to mission.", "category": "ScopeControl" },
    { "id": "request_team_support", "description": "Request additional human or agent support.", "category": "GovernanceControl" },
    { "id": "switch_to_low_latency_mode", "description": "Switch systems to low-latency configuration.", "category": "SystemControl" },
    { "id": "report_system_delay", "description": "Report latency issues to architecture and governance.", "category": "GovernanceControl" },
    { "id": "freeze_noncritical_actions", "description": "Freeze all noncritical operations under critical override.", "category": "SystemControl" },
    { "id": "full_stop", "description": "Stop all operations immediately.", "category": "SystemControl" },
    { "id": "transfer_control", "description": "Transfer control to higher authority.", "category": "CommandControl" },
    { "id": "tighten_constraints", "description": "Increase strictness of operational constraints.", "category": "ConstraintControl" },
    { "id": "issue_drift_correction", "description": "Issue directive to correct observed drift.", "category": "GovernanceControl" },
    { "id": "redistribute_workload", "description": "Reassign tasks to balance coordination load.", "category": "ScopeControl" },
    { "id": "increase_sync_frequency", "description": "Increase synchronization cadence between teams.", "category": "GovernanceControl" },
    { "id": "enforce_tempo_reduction", "description": "Enforce reduced tempo across teams.", "category": "CommandControl" },
    { "id": "adjust_shift_patterns", "description": "Change staffing or shift patterns to reduce overload.", "category": "GovernanceControl" },
    { "id": "initiate_conflict_resolution", "description": "Start conflict resolution process to repair trust.", "category": "GovernanceControl" },
    { "id": "increase_transparency", "description": "Increase information sharing to restore trust.", "category": "GovernanceControl" },
    { "id": "enforce_hard_constraints", "description": "Apply non-negotiable constraints to operations.", "category": "ConstraintControl" },
    { "id": "escalate_to_governance", "description": "Escalate situation to governance leadership.", "category": "GovernanceControl" },
    { "id": "execute_command_seizure", "description": "Seize command from lower-level actors.", "category": "CommandControl" },
    { "id": "run_short_interval_simulations", "description": "Run rapid simulations to probe drift and contradictions.", "category": "SimulationControl" },
    { "id": "identify_drift_source", "description": "Identify root cause of drift or contradiction.", "category": "SimulationControl" },
    { "id": "inject_environmental_scenarios", "description": "Inject new environmental scenarios into simulations.", "category": "SimulationControl" },
    { "id": "recompute_risk_surface", "description": "Recompute risk landscape under new conditions.", "category": "SimulationControl" },
    { "id": "model_drift_acceleration", "description": "Model acceleration of drift over time.", "category": "SimulationControl" },
    { "id": "recommend_countermeasures", "description": "Recommend countermeasures to slow or reverse drift.", "category": "SimulationControl" },
    { "id": "compute_least_harm_path", "description": "Compute action path with minimal harm to positive goals.", "category": "SimulationControl" },
    { "id": "inject_alternative_paths", "description": "Inject alternative action paths into operations.", "category": "SimulationControl" },
    { "id": "lead_forensic_capture", "description": "Lead capture of logs and traces for post-incident analysis.", "category": "ForensicControl" },
    { "id": "trigger_corrective_action_plan", "description": "Trigger formal corrective action process.", "category": "GovernanceControl" },
    { "id": "audit_goal_alignment", "description": "Audit alignment between goals and behavior.", "category": "GovernanceControl" },
    { "id": "issue_alignment_directive", "description": "Issue directive to restore alignment.", "category": "GovernanceControl" },
    { "id": "initiate_systemic_risk_review", "description": "Initiate review of systemic risk across subsystems.", "category": "GovernanceControl" },
    { "id": "coordinate_cross_team_mitigation", "description": "Coordinate mitigation actions across teams.", "category": "GovernanceControl" },
    { "id": "initiate_harm_containment", "description": "Start harm containment procedures.", "category": "GovernanceControl" },
    { "id": "initiate_override_governance", "description": "Start governance process for critical override.", "category": "GovernanceControl" },
    { "id": "lead_emergency_stabilization", "description": "Lead emergency stabilization efforts.", "category": "GovernanceControl" },
    { "id": "tune_negative_goal_monitor", "description": "Tune sensitivity of negative-goal monitoring.", "category": "SystemControl" },
    { "id": "adjust_conflict_sensitivity", "description": "Adjust sensitivity of conflict detection.", "category": "SystemControl" },
    { "id": "deploy_FRA01", "description": "Deploy FRA-01 fractal escalation detection engine.", "category": "SystemControl" },
    { "id": "deploy_TBTF", "description": "Deploy TBTF systemic destabilization analysis engine.", "category": "SystemControl" },
    { "id": "reroute_system_flows", "description": "Reroute flows to safer system paths.", "category": "SystemControl" },
    { "id": "isolate_risky_subgraphs", "description": "Isolate risky parts of the system graph.", "category": "SystemControl" },
    { "id": "deploy_IIP_IOSEFE", "description": "Deploy IIP-IOSEFE harm-loop detection engine.", "category": "SystemControl" },
    { "id": "isolate_subsystem", "description": "Isolate entire subsystem from broader architecture.", "category": "SystemControl" },
    { "id": "issue_strategic_realignment", "description": "Issue strategic-level realignment of goals and priorities.", "category": "CommandControl" },
    { "id": "authorize_operational_freeze", "description": "Authorize freeze of operations.", "category": "CommandControl" },
