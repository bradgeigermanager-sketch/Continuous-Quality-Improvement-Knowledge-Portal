{
  "engine": {
    "name": "NGODE-CIOS-Simulation-Engine",
    "version": "1.0.0",
    "tickIntervalMs": 1000
  },
  "telemetryModel": {
    "primarygoalintegrity": 1.0,
    "negativegoalactivation": 0.0,
    "conflict_index": 0.0,
    "predictedpositivegoal_harm": 0.0,
    "override_probability": 0.0,
    "violation_severity": "NoViolation",
    "operational_tempo": 0.0,
    "resource_utilization": 0.0,
    "coordination_load": 0.0,
    "environmental_volatility": 0.0,
    "drift_momentum": 0.0,
    "cognitive_load": 0.0,
    "system_latency": 0.0,
    "trust_degradation": 0.0,
    "alignment_dissonance": 0.0,
    "systemic_risk_index": 0.0
  },
  "channels": [
    {
      "id": "IntegrityChannel",
      "sourceField": "primarygoalintegrity",
      "fireWhen": { "mode": "THRESHOLD", "operator": "<", "threshold": 0.85 },
      "description": "Fires when positive-goal integrity weakens below acceptable bounds."
    },
    {
      "id": "EscalationChannel",
      "sourceField": "negativegoalactivation",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.40 },
      "description": "Fires when negative-goal pursuit becomes abnormally strong."
    },
    {
      "id": "ContradictionChannel",
      "sourceField": "conflict_index",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.30 },
      "description": "Fires when predicted outcomes show conflict between positive and negative goals."
    },
    {
      "id": "HarmForecastChannel",
      "sourceField": "predictedpositivegoal_harm",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.25 },
      "description": "Fires when predicted harm to protected positive goals exceeds safe limits."
    },
    {
      "id": "InversionRiskChannel",
      "sourceField": "override_probability",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.20 },
      "description": "Fires when the probability of goal-priority inversion becomes significant."
    },
    {
      "id": "VerdictChannel",
      "sourceField": "violation_severity",
      "fireWhen": { "mode": "ALWAYS" },
      "description": "Broadcast channel that fires every tick with the NGODE verdict."
    },
    {
      "id": "TempoChannel",
      "sourceField": "operational_tempo",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.70 },
      "description": "Fires when operational tempo exceeds sustainable cognitive or organizational bandwidth."
    },
    {
      "id": "ResourceStrainChannel",
      "sourceField": "resource_utilization",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.80 },
      "description": "Fires when resource utilization approaches critical strain."
    },
    {
      "id": "CoordinationLoadChannel",
      "sourceField": "coordination_load",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.60 },
      "description": "Fires when coordination complexity or cross-role synchronization load becomes unstable."
    },
    {
      "id": "EnvironmentalVolatilityChannel",
      "sourceField": "environmental_volatility",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.50 },
      "description": "Fires when external conditions become volatile or unpredictable."
    },
    {
      "id": "DriftMomentumChannel",
      "sourceField": "drift_momentum",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.20 },
      "description": "Fires when the rate of drift acceleration indicates a self-reinforcing deviation pattern."
    },
    {
      "id": "CognitiveLoadChannel",
      "sourceField": "cognitive_load",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.75 },
      "description": "Fires when human or agent cognitive load exceeds safe operational thresholds."
    },
    {
      "id": "LatencyChannel",
      "sourceField": "system_latency",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.30 },
      "description": "Fires when system latency or decision lag threatens operational timing integrity."
    },
    {
      "id": "TrustDegradationChannel",
      "sourceField": "trust_degradation",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.25 },
      "description": "Fires when trust signals between agents or teams degrade beyond acceptable limits."
    },
    {
      "id": "AlignmentDissonanceChannel",
      "sourceField": "alignment_dissonance",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.35 },
      "description": "Fires when behavioral patterns diverge from declared goals or mission parameters."
    },
    {
      "id": "SystemicRiskChannel",
      "sourceField": "systemic_risk_index",
      "fireWhen": { "mode": "THRESHOLD", "operator": ">", "threshold": 0.40 },
      "description": "Fires when interconnected subsystems show signs of cascading failure or instability."
    }
  ],
  "routing": [
    { "channelId": "IntegrityChannel", "recipients": ["Supervisor", "GovernanceLead", "Executive"] },
    { "channelId": "EscalationChannel", "recipients": ["Operator", "Supervisor", "Architect"] },
    { "channelId": "ContradictionChannel", "recipients": ["CISpecialist", "Architect", "GovernanceLead"] },
    { "channelId": "HarmForecastChannel", "recipients": ["GovernanceLead", "Executive", "CISpecialist"] },
    { "channelId": "InversionRiskChannel", "recipients": ["Architect", "Executive", "GovernanceLead"] },
    { "channelId": "VerdictChannel", "recipients": ["Operator", "Supervisor", "CISpecialist", "GovernanceLead", "Architect", "Executive"] },
    { "channelId": "TempoChannel", "recipients": ["Operator", "Supervisor"] },
    { "channelId": "ResourceStrainChannel", "recipients": ["Operator"] },
    { "channelId": "CoordinationLoadChannel", "recipients": ["Supervisor"] },
    { "channelId": "EnvironmentalVolatilityChannel", "recipients": ["CISpecialist", "Executive"] },
    { "channelId": "DriftMomentumChannel", "recipients": ["CISpecialist"] },
    { "channelId": "CognitiveLoadChannel", "recipients": ["Operator"] },
    { "channelId": "LatencyChannel", "recipients": ["Operator"] },
    { "channelId": "TrustDegradationChannel", "recipients": ["Supervisor"] },
    { "channelId": "AlignmentDissonanceChannel", "recipients": ["GovernanceLead"] },
    { "channelId": "SystemicRiskChannel", "recipients": ["GovernanceLead", "Architect"] }
  ],
  "roles": [
    {
      "id": "Operator",
      "displayName": "Frontline Operator",
      "actions": [
        {
          "on": "EscalationChannel",
          "conditions": [],
          "steps": [
            { "actionId": "reduce_scope", "params": {} },
            { "actionId": "apply_soft_realignment", "params": {} },
            { "actionId": "switch_to_constraint_first", "params": {} }
          ]
        },
        {
          "on": "TempoChannel",
          "conditions": [],
          "steps": [
            { "actionId": "slow_operational_tempo", "params": {} },
            { "actionId": "request_supervisor_review", "params": {} }
          ]
        },
        {
          "on": "ResourceStrainChannel",
          "conditions": [],
          "steps": [
            { "actionId": "prioritize_tasks", "params": {} },
            { "actionId": "shed_noncritical_load", "params": {} }
          ]
        },
        {
          "on": "CognitiveLoadChannel",
          "conditions": [],
          "steps": [
            { "actionId": "pause_nonessential_tasks", "params": {} },
            { "actionId": "request_team_support", "params": {} }
          ]
        },
        {
          "on": "LatencyChannel",
          "conditions": [],
          "steps": [
            { "actionId": "switch_to_low_latency_mode", "params": {} },
            { "actionId": "report_system_delay", "params": {} }
          ]
        },
        {
          "on": "VerdictChannel",
          "conditions": [
            { "field": "violation_severity", "operator": "==", "value": "CriticalOverride" }
          ],
          "steps": [
            { "actionId": "freeze_noncritical_actions", "params": {} }
          ]
        },
        {
          "on": "VerdictChannel",
          "conditions": [
            { "field": "violation_severity", "operator": "==", "value": "CatastrophicInversion" }
          ],
          "steps": [
            { "actionId": "full_stop", "params": {} },
            { "actionId": "transfer_control", "params": {} }
          ]
        }
      ]
    },
    {
      "id": "Supervisor",
      "displayName": "Team Lead / Supervisor",
      "actions": [
        {
          "on": "IntegrityChannel",
          "conditions": [],
          "steps": [
            { "actionId": "tighten_constraints", "params": {} },
            { "actionId": "issue_drift_correction", "params": {} }
          ]
        },
        {
          "on": "CoordinationLoadChannel",
          "conditions": [],
          "steps": [
            { "actionId": "redistribute_workload", "params": {} },
            { "actionId": "increase_sync_frequency", "params": {} }
          ]
        },
        {
          "on": "TempoChannel",
          "conditions": [],
          "steps": [
            { "actionId": "enforce_tempo_reduction", "params": {} },
            { "actionId": "adjust_shift_patterns", "params": {} }
          ]
        },
        {
          "on": "TrustDegradationChannel",
          "conditions": [],
          "steps": [
            { "actionId": "initiate_conflict_resolution", "params": {} },
            { "actionId": "increase_transparency", "params": {} }
          ]
        },
        {
          "on": "VerdictChannel",
          "conditions": [
            { "field": "violation_severity", "operator": "==", "value": "CriticalOverride" }
          ],
          "steps": [
            { "actionId": "enforce_hard_constraints", "params": {} },
            { "actionId": "escalate_to_governance", "params": {} }
          ]
        },
        {
          "on": "VerdictChannel",
          "conditions": [
            { "field": "violation_severity", "operator": "==", "value": "CatastrophicInversion" }
          ],
          "steps": [
            { "actionId": "execute_command_seizure", "params": {} }
          ]
        }
      ]
    },
    {
