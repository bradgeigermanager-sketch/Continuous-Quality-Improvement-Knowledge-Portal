          ]
        },
        {
          "on": "EnvironmentalVolatilityChannel",
          "conditions": [],
          "steps": [
            { "actionId": "inject_environmental_scenarios", "params": {} },
            { "actionId": "recompute_risk_surface", "params": {} }
          ]
        },
        {
          "on": "DriftMomentumChannel",
          "conditions": [],
